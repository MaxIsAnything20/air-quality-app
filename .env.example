# Server-side only — deliberately NOT prefixed with VITE_. That prefix is
# what tells Vite to inline a value into the client bundle, which is exactly
# what we're avoiding now that AirNow/PurpleAir requests are proxied through
# the Vite dev middleware (vite.config.ts) and, in production, through the
# serverless functions in api/. The browser never sees these values.

# Get a free key at https://docs.airnowapi.org -> "Request an AirNow API Account"
AIRNOW_API_KEY=

# Get a free "Read" key at https://develop.purpleair.com (sign in with Google)
PURPLEAIR_API_KEY=

# Optional — enables the real AI-generated plain-language summary via
# api/summary.ts (and its dev equivalent in vite.config.ts). Without this,
# the app falls back to a local, rule-based summary (the fallbackSummary()
# function in src/hooks/useSummary.ts) — same "never just breaks" pattern as
# everything else here.
ANTHROPIC_API_KEY=

# --- Background push notifications (see PUSH_SETUP.md) ---

# Auto-injected once you provision a Redis store from the Vercel dashboard
# (Storage -> Marketplace Database Providers -> Upstash). Not needed for
# local dev unless you're testing background alerts locally against a real
# store — leave blank otherwise.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Generate with: npx web-push generate-vapid-keys
# The PUBLIC key is not secret — it's also set as VITE_VAPID_PUBLIC_KEY
# below with the identical value, since the browser needs it too.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Required by the web-push spec — a contact address for your VAPID
# identity, e.g. mailto:you@example.com. Not secret.
VAPID_SUBJECT=

# A random string only you and your GitHub Actions workflow know — proves
# /api/push/check requests are actually coming from your scheduled
# workflow, not a random request to the public URL. Generate any way you
# like, e.g.: openssl rand -hex 32
CRON_SECRET=

# Client-exposed on purpose — see VAPID_PUBLIC_KEY above and
# src/services/pushSubscription.ts's header comment for why this one
# (and only this one) is safe to ship in the browser bundle.
VITE_VAPID_PUBLIC_KEY=
