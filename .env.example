# Server-side only — deliberately NOT prefixed with VITE_. That prefix is
# what tells Vite to inline a value into the client bundle, which is exactly
# what we're avoiding now that AirNow/PurpleAir requests are proxied through
# the Vite dev middleware (vite.config.ts) and, in production, through the
# serverless functions in api/. The browser never sees these values.

# Get a free key at https://docs.airnowapi.org -> "Request an AirNow API Account"
AIRNOW_API_KEY=

# Get a free "Read" key at https://develop.purpleair.com (sign in with Google)
PURPLEAIR_API_KEY=

# Optional — enables the real AI-generated plain-language summary via
# api/summary.ts (and its dev equivalent in vite.config.ts). Without this,
# the app falls back to a local, rule-based summary (the fallbackSummary()
# function in src/hooks/useSummary.ts) — same "never just breaks" pattern as
# everything else here.
ANTHROPIC_API_KEY=
