{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "^/api/airnow/(.*)$", "destination": "/api/airnow?upstreamPath=/$1" },
    { "source": "^/api/purpleair/(.*)$", "destination": "/api/purpleair?upstreamPath=/$1" },
    { "source": "^/api/smoke/(.*)$", "destination": "/api/smoke?upstreamPath=/$1" },
    { "source": "^/api/fire/(.*)$", "destination": "/api/fire?upstreamPath=/$1" }
  ]
}
