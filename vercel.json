{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/airnow/:upstreamPath*", "destination": "/api/airnow" },
    { "source": "/api/purpleair/:upstreamPath*", "destination": "/api/purpleair" },
    { "source": "/api/smoke/:upstreamPath*", "destination": "/api/smoke" },
    { "source": "/api/fire/:upstreamPath*", "destination": "/api/fire" }
  ]
}
